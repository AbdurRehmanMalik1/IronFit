# =====================================================
# Android Studio / Kotlin / Java — .gitignore
# =====================================================

# --------------------- idea -----------------------
*.iml
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml

# --------------------- gradle ---------------------
.gradle
/build
/captures
.externalNativeBuild
.cxx

# --------------------- local config ---------------
local.properties
keystore.properties

# --------------------- secrets / api keys ---------
*.jks
*.keystore
google-services.json
secrets.properties
apikeys.properties
*.env

# --------------------- OS generated ---------------
.DS_Store
Thumbs.db
desktop.ini

# --------------------- build output ---------------
*.apk
*.aab
*.dex
*.class
out/
bin/
gen/





#--------------------- Nest Js Ignores ---------------


# =====================
# NESTJS / NODE BACKEND
# =====================

# dependencies
/backend/node_modules/
/backend/dist/
/backend/build/

# environment files
/backend/.env
/backend/.env.*
!/backend/.env.example

# logs
/backend/npm-debug.log*
/backend/yarn-debug.log*
/backend/yarn-error.log*
/backend/pnpm-debug.log*

# runtime
/backend/.DS_Store
/backend/*.pid
/backend/*.seed

# NestJS cache / compiled
/backend/.nestjs
/backend/coverage/

# IDE / editor
/backend/.idea/
/backend/.vscode/

# =====================
# GENERAL
# =====================

.DS_Store
.idea/
.vscode/
*.log

